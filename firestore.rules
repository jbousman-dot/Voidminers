rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Player saves — each user can read/write their own save
    match /saves/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Leaderboard — anyone can read, authenticated users can write their own entry
    match /leaderboard/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.data.keys().hasOnly(['name', 'sector', 'era', 'ascensions', 'updatedAt'])
        && request.resource.data.sector is number
        && request.resource.data.era is number;
    }
  }
}
