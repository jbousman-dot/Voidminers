rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Player saves — open read/write since Cloudflare Access gates the site
    // Each save is keyed by the user's CF Access sub claim
    match /saves/{userId} {
      allow read, write: if true;
    }

    // Leaderboard — public read, anyone can write their own entry
    match /leaderboard/{userId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
